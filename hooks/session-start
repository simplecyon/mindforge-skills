#!/usr/bin/env bash
# SessionStart hook for mindforge plugin
# Injects the using-mindforge entry skill into session context.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-mindforge content
using_mindforge_content=$(cat "${PLUGIN_ROOT}/skills/using-mindforge/SKILL.md" 2>&1 || echo "Error reading using-mindforge skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_mindforge_escaped=$(escape_for_json "$using_mindforge_content")
session_context="<MINDFORGE>\nYou have mindforge — a structured thinking skillset.\n\n**Below is the full content of your 'mindforge:using-mindforge' skill — your guide to when to use each thinking skill. For the individual skills (clarifier, muse, thinker, janus, conductor), use the 'Skill' tool:**\n\n${using_mindforge_escaped}\n</MINDFORGE>"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
